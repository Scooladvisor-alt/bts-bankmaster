{
  "name": "Course",
  "type": "object",
  "properties": {
    "subject": {
      "type": "string",
      "enum": [
        "VOJES",
        "CESBF"
      ]
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string",
      "description": "Contenu du cours (markdown support\u00e9)"
    },
    "order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "subject",
    "title",
    "content"
  ]
}